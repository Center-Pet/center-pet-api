# =============================================================================
# .env (dotenv-flow) — desenvolvimento local. NÃO commite (está no .gitignore).
# Modelo completo e origens: ver .env.example
# =============================================================================

# Render / local — fallback de porta no server.js: 5000
PORT=5000

# npm script ou manual — production | development
NODE_ENV=development

# MongoDB Atlas → connect string
MONGO_URI=mongodb+srv://USUARIO:SENHA@cluster.mongodb.net/NomeDatabase?retryWrites=true&w=majority

# Segredo JWT — openssl rand -base64 48 — mesmo no Render
JWT_SECRET=

# Opcional — mesma ideia que JWT ou outro segredo forte
APP_SECRET=

# Front para links em e-mail — Netlify/Vercel ou localhost
FRONTEND_URL=http://localhost:8081

# Gmail app password ou outro SMTP
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=

# New Relic → License key → Render Environment (opcional em dev)
NEW_RELIC_LICENSE_KEY=
# New Relic → nome do app APM (fallback em newrelic.js: center-pet-api)
NEW_RELIC_APP_NAME=center-pet-api
