# =============================================================================
# Center Pet API — variáveis de ambiente (dotenv-flow)
# Copie este arquivo para .env, .env.development e/ou .env.production e ajuste.
# Origem de cada valor está no comentário à direita ou na linha acima da chave.
# =============================================================================

# --- Servidor ---
# PORT: fallback 5000 no código (server.js). Render injeta PORT automaticamente no deploy.
PORT=5000

# NODE_ENV: definido pelo script npm (cross-env) ou pelo Render; típico development | production
NODE_ENV=development

# --- Banco de dados ---
# MONGO_URI: MongoDB Atlas → Project → Database → Connect → Drivers → string de conexão SRV
MONGO_URI=mongodb+srv://USUARIO:SENHA@cluster.mongodb.net/NomeDatabase?retryWrites=true&w=majority

# --- Autenticação JWT ---
# JWT_SECRET: valor forte gerado por você (ex.: openssl rand -base64 48). Mesmo valor no Render.
JWT_SECRET=

# APP_SECRET: usado em trechos legados (adopter/ong); idealmente igual a JWT_SECRET ou outro segredo. Render / .env local.
APP_SECRET=

# --- Links no e-mail (reset senha, adoção) ---
# FRONTEND_URL: URL pública do front (Netlify, Vercel, etc.), sem barra final desnecessária.
FRONTEND_URL=http://localhost:8081

# --- E-mail (Nodemailer) ---
# EMAIL_SERVICE: provedor (ex.: gmail). Gmail → usar "Senhas de app" na conta Google.
EMAIL_SERVICE=gmail
# EMAIL_USER / EMAIL_PASS: conta e senha de app (nunca commite o .env preenchido)
EMAIL_USER=
EMAIL_PASS=

# --- New Relic APM (Node) ---
# NEW_RELIC_LICENSE_KEY: New Relic → Ingest - License key (ou guia Node.js). Render → Environment.
NEW_RELIC_LICENSE_KEY=
# NEW_RELIC_APP_NAME: nome do app em APM (New Relic UI). Fallback no código: center-pet-api
NEW_RELIC_APP_NAME=center-pet-api
